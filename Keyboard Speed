-- Función para apagar todo y detener trayectorias
local run1, run2, run3, run4 = false, false, false, false
local btn1, btn2, btn3, btn4

local function apagarTodo()
    run1 = false; run2 = false; run3 = false; run4 = false
    if btn1 then btn1.Text = "Stage 1: OFF"; btn1.TextColor3 = Color3.fromRGB(255,80,80) end
    if btn2 then btn2.Text = "Stage 2: OFF"; btn2.TextColor3 = Color3.fromRGB(255,80,80) end
    if btn3 then btn3.Text = "Stage 3: OFF"; btn3.TextColor3 = Color3.fromRGB(255,80,80) end
    if btn4 then btn4.Text = "1K: OFF"; btn4.TextColor3 = Color3.fromRGB(255,80,80) end
end

-- Detectar muerte del jugador
player.CharacterAdded:Connect(function(char)
    char:WaitForChild("Humanoid").Died:Connect(function()
        apagarTodo()
    end)
end)
if player.Character then
    player.Character:WaitForChild("Humanoid").Died:Connect(function()
        apagarTodo()
    end)
end

local dragging, dragStart, startPos
frame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = frame.Position
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
frame.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)

local function crearBoton(nombre, posY)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0,160,0,45)
    btn.Position = UDim2.new(0.5,-80,0,posY)
    btn.BackgroundColor3 = Color3.fromRGB(35,35,35)
    btn.Text = nombre .. ": OFF"
    btn.TextColor3 = Color3.fromRGB(255,80,80)
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 18
    btn.Parent = frame
    local stroke = Instance.new("UIStroke")
    stroke.Thickness = 2
    stroke.Parent = btn
    return btn
end

btn1 = crearBoton("Stage 1", 40)
btn2 = crearBoton("Stage 2", 95)
btn3 = crearBoton("Stage 3", 150)
btn4 = crearBoton("1K", 205)

local function mover(hrp, cf, tiempo)
    local tween = TweenService:Create(hrp, TweenInfo.new(tiempo, Enum.EasingStyle.Linear), {CFrame = CFrame.new(cf)})
    tween:Play()
    tween.Completed:Wait()
end

btn1.MouseButton1Click:Connect(function()
    local activar = not run1
    apagarTodo()
    run1 = activar
    if run1 then
        btn1.Text = "Stage 1: ON"; btn1.TextColor3 = Color3.fromRGB(80,255,80)
        task.spawn(function()
            while run1 do
                local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                if hrp then
                    mover(hrp, Vector3.new(5.066667556762695,10.603286743164062,3.919901132583618), 0.3)
                    if not run1 then break end
                    mover(hrp, Vector3.new(-16.488636016845703,6.857143402099609,284.7413024902344), 2)
                    task.wait(0.5)
                else break end
            end
        end)
    end
end)

